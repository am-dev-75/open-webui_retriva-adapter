# Required
OWUI_BASE_URL=http://localhost:3000
OWUI_API_KEY=your-openwebui-api-key

# Retriva connection
RETRIVA_API_PROTOCOL=http
RETRIVA_INGESTION_API_HOST=localhost
RETRIVA_INGESTION_PORT=8000
RETRIVA_CHAT_API_HOST=localhost
RETRIVA_CHAT_PORT=8001

# Optional
# RETRIVA_API_KEY=
# POLL_INTERVAL_SECONDS=30
# DB_PATH=./data/adapter.db
LOG_LEVEL=INFO
ADAPTER_PORT=8002

# Metadata / KB
# DEFAULT_KB_ID=

# Debugging
# THIN_ADAPTER_DEBUG_ENDPOINTS=false

# Chat polling (directive observation)
# CHAT_POLL_ENABLED=true
# CHAT_POLL_INTERVAL_SECONDS=5

# Retry / Timeout tuning
# MAX_RETRIES=3
# BACKOFF_BASE_SECONDS=1.0
# BACKOFF_MAX_SECONDS=30.0
# HTTP_TIMEOUT_SECONDS=60.0
